<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          package="com.reflect.sdk">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- Required on Android 13+ to read the Google Advertising ID.
         KIDS / COPPA APPS: do NOT ship this permission. Set ReflectConfig.CoppaCompliant=true
         (stops the SDK reading GAID/IDFA at runtime) AND add the scripting define
         REFLECT_COPPA so the build auto-strips this line from the merged manifest. -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID"/>

    <queries>
        <!-- Required so PackageManager.getInstallerPackageName works on Android 11+. -->
        <package android:name="com.android.vending"/>
        <!-- Store install-referrer content providers (Meta / Samsung / Xiaomi) must be
             declared here to be queryable on Android 11+ package visibility. -->
        <provider android:authorities="com.facebook.katana.provider.InstallReferrerProvider"/>
        <provider android:authorities="com.instagram.android.provider.InstallReferrerProvider"/>
        <provider android:authorities="com.sec.android.app.samsungapps.installreferrer"/>
        <provider android:authorities="com.xiaomi.market.installreferrer"/>
    </queries>

    <application />
</manifest>
